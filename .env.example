# Copy this file to `.env` and fill in your key.
# `.env` is git-ignored — never commit real keys.

# Your Gemini API key (from https://aistudio.google.com/apikey).
# If unset, ranking falls back to keyword scoring (still produces a page).
GEMINI_API_KEY=your_key_here

# Optional: override the ranking model. Default is gemini-3.5-flash.
# Provider is inferred from the name: deepseek-* -> DeepSeek, else Gemini.
# GEMINI_MODEL=deepseek-v4-flash

# DeepSeek key (only needed if you pick a deepseek-* model). From
# https://platform.deepseek.com — cheap and strong at financial reasoning.
# DEEPSEEK_API_KEY=your_deepseek_key_here

# Optional: model used to build the portfolio exposure graph (reasoning-heavy,
# run once + cached). Defaults to the ranking model; deepseek-v4-pro is ideal.
# GRAPH_MODEL=deepseek-v4-pro
